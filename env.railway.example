# Railway environment variables for Queueless
NODE_ENV=production
SERVE_FRONTEND=true

# Railway sets PORT automatically; do not hardcode unless needed

# Required
JWT_SECRET=replace-with-a-strong-random-secret
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
CORS_ORIGIN=https://your-app.up.railway.app

# Optional when frontend is on Vercel and you want preview branches to work
# CORS_ORIGIN_REGEX=^https:\/\/[a-z0-9-]+\.vercel\.app$

# Optional seed admin
ADMIN_NAME=QueueLess Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
