# Runtime
NODE_ENV=production
PORT=5000

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/queueless

# Security
JWT_SECRET=replace-with-a-strong-random-secret

# Comma-separated list of allowed frontend origins (exact match)
# Example: https://queueless.example.com,https://www.queueless.example.com
CORS_ORIGIN=http://localhost:3000

# Auto-seed admin on first startup (optional)
ADMIN_NAME=QueueLess Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# Serve frontend static files from backend service
SERVE_FRONTEND=true
