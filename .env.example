# Required for JWT signing in backend
JWT_SECRET=replace-with-a-strong-random-secret

# Allowed browser origins for API/WebSocket calls
# For local compose usage keep this as http://localhost:5000
CORS_ORIGIN=http://localhost:5000

# Optional first-run admin seed
ADMIN_NAME=QueueLess Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!




