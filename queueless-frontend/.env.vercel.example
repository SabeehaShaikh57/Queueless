# Vercel Frontend Environment Variables (set in Vercel project settings)

# Required: full backend API base URL (must include /api)
QL_API_BASE=https://your-backend-domain.com/api

# Required: backend socket origin (no /api suffix)
QL_SOCKET_BASE=https://your-backend-domain.com

# Example values if backend is on Render
# QL_API_BASE=https://your-backend.onrender.com/api
# QL_SOCKET_BASE=https://your-backend.onrender.com
